{% for thread in active_threads %}
<Thread ID="{{ thread.id }}">
Recent Messages:
{% for msg in thread.messages %}
- [{{ msg.time_display }}] {{ msg.sender }}: {{ msg.text }}
{% endfor %}
</Thread>
{% endfor %}
Target Message:
[{{ target_message.time_display }}] {{ target_message.sender }}: {{ target_message.text }}
Future Context:
{% if future_messages %}
{% for msg in future_messages %}
- [{{ msg.time_display }}] {{ msg.sender }}: {{ msg.text }}
{% endfor %}
{% else %}
No future messages available.
{% endif %}
{% if warning_message %}
### SYSTEM WARNING FROM PREVIOUS ATTEMPT
{{ warning_message }}
Please fix the error and output ONLY the exact integer Thread ID (or 0). No other text is allowed.
{% endif %}
### OUTPUT